# syntax=docker/dockerfile:1.7
# =============================================================================
# AOS Purpose-Driven Agent — Layer 2 of the ACR neutral network
#
# FROM line is the manifest — the only cross-layer dependency declaration.
# Updated automatically via manifest-update PR when the parent layer changes.
# Do not edit the digest by hand.
#
# Layer contract:
#   INPUT:  parent image (.pyc bytecode of all lower layers)
#   ADD:    this layer's .pyc (compiled from src/ in this repo)
#   OUTPUT: parent .pyc + this layer's .pyc — no .py source anywhere
#
# Build: ACR Task triggered by az acr build — runs inside Azure.
#        Build context: src/ directory only (~50KB).
#        No image pulled to GitHub runner.
#
# Rebase: when parent digest changes (non-breaking bump), this image is
#         remanifested via crane rebase — no recompilation, no ACR Task.
# =============================================================================

FROM acraosstagingerm2srfd.azurecr.io/aos/infra@sha256:37c5f677d231215124d7c1de19bbace9a24b54db24906687e734c2e79c88af61

LABEL org.opencontainers.image.title="AOS Purpose-Driven Agent"
LABEL org.opencontainers.image.description="Layer 2: PurposeDrivenAgent — compiled bytecode only"
LABEL org.opencontainers.image.vendor="ASI Saga"
LABEL org.opencontainers.image.source="https://github.com/ASISaga/purpose-driven-agent"
LABEL aos.layer="2"
LABEL aos.layer.name="purpose-driven-agent"
LABEL aos.network="neutral"
LABEL aos.parent.digest="sha256:37c5f677d231215124d7c1de19bbace9a24b54db24906687e734c2e79c88af61"

WORKDIR /app

# Copy pre-compiled .pyc files from the ACR Task build context.
# The ACR Task compiles src/ → .pyc before sending the build context,
# so this COPY receives only bytecode — no .py source enters the image.
COPY --chown=aosuser:aosuser compiled/purpose_driven_agent/ ./purpose_driven_agent/
COPY --chown=aosuser:aosuser compiled/aos_mcp_servers/ ./aos_mcp_servers/

ENV PYTHONPATH=/app:/app/lib/python3.12/site-packages

# Verify: no .py source, .pyc present, import chain works
RUN python -c "\
import pathlib; \
py  = list(pathlib.Path('/app/purpose_driven_agent').rglob('*.py')) + \
      list(pathlib.Path('/app/aos_mcp_servers').rglob('*.py')); \
pyc = list(pathlib.Path('/app/purpose_driven_agent').rglob('*.pyc')) + \
      list(pathlib.Path('/app/aos_mcp_servers').rglob('*.pyc')); \
assert len(py)  == 0, f'Found .py source: {py}'; \
assert len(pyc)  > 0, 'No .pyc files found'; \
print(f'Layer 2: 0 .py, {len(pyc)} .pyc. OK') \
"

USER aosuser
CMD ["python", "-m", "purpose_driven_agent"]